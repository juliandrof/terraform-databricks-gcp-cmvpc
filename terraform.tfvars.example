databricks_account_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
gcp_project_id        = "my-gcp-project"
gcp_region            = "us-central1"
workspace_name        = "my-databricks-workspace"
vpc_name              = "databricks-vpc"

# Adjust CIDR range as needed — each GCE compute node uses 2 IPs
# /20 supports ~2,000 concurrent nodes
subnet_ip_cidr_range = "10.0.0.0/20"
