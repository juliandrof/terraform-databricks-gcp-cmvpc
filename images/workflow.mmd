flowchart TD
    S1["<b>STEP 1</b><br/>Install Prerequisites<br/><i>Terraform · gcloud CLI · Databricks CLI</i>"]
    S2["<b>STEP 2</b><br/>Authenticate<br/><i>GCP Service Account + Databricks Account API</i>"]
    S3["<b>STEP 3</b><br/>Configure Variables<br/><i>edit terraform.tfvars</i>"]
    S4["<b>STEP 4</b><br/>terraform init<br/><i>Download providers and modules</i>"]
    S5["<b>STEP 5</b><br/>terraform plan<br/><i>Review planned changes</i>"]
    DEC{Plan looks good?}
    S6["<b>STEP 6</b><br/>terraform apply<br/><i>Deploy infrastructure to GCP</i>"]
    S7["<b>STEP 7</b><br/>Access Workspace<br/><i>Open workspace URL from outputs</i>"]

    S1 --> S2
    S2 --> S3
    S3 --> S4
    S4 --> S5
    S5 --> DEC
    DEC -->|Yes| S6
    DEC -->|"No — revise config"| S3
    S6 --> S7

