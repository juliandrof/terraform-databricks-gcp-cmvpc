flowchart TB
    CONSOLE["Databricks Account Console\naccounts.gcp.databricks.com\nWorkspace Lifecycle Management"]

    subgraph GCP ["  GCP Project  "]
        direction TB

        subgraph CP ["  Databricks Control Plane  (Managed by Databricks)  "]
            direction LR
            MWS["MWS API\nWorkspace provisioning\nand network configuration"]
            DBAPI["Databricks REST API\nCluster and job management"]
        end

        subgraph CMVPC ["  Customer-Managed VPC  "]
            direction TB

            FW["Firewall Rules\nAllow internal TCP/UDP\nbetween compute nodes"]

            subgraph SUBNET ["  Subnet  10.0.0.0/20  "]
                direction LR
                GCE1["GCE VM Instance\nDriver Node\nPrivate IP only"]
                GCE2["GCE VM Instance\nWorker Node\nPrivate IP only"]
                GCE3["GCE VM Instance\nWorker Node\nPrivate IP only"]
            end

            subgraph EGRESS ["  Outbound Internet Access  "]
                direction LR
                ROUTER["Cloud Router\nDynamic routing"]
                NAT["Cloud NAT\nOutbound internet for\nprivate VMs — no inbound"]
            end
        end
    end

    INTERNET(("Internet\n(Databricks CP\nand package repos)"))

    CONSOLE -->|"MWS API calls HTTPS"| MWS
    MWS -->|"Provisions workspace\nand network config"| CMVPC
    DBAPI -->|"Launch and manage clusters"| GCE1
    DBAPI -->|"Launch and manage clusters"| GCE2
    DBAPI -->|"Launch and manage clusters"| GCE3

    FW -->|"Protects"| SUBNET
    GCE1 <-->|"Spark shuffle\nand heartbeat"| GCE2
    GCE1 <-->|"Spark shuffle\nand heartbeat"| GCE3
    GCE2 <-->|"Spark shuffle\nand heartbeat"| GCE3

    SUBNET -->|"Outbound traffic\nvia NAT"| ROUTER
    ROUTER --> NAT
    NAT -->|"Egress only HTTPS"| INTERNET

    classDef externalNode fill:#1a73e8,stroke:#0d47a1,color:#ffffff
    classDef apiNode fill:#e8f0fe,stroke:#4285f4,color:#1a237e
    classDef gceNode fill:#fce8b2,stroke:#f9ab00,color:#3e2723
    classDef networkNode fill:#d2e3fc,stroke:#1a73e8,color:#1a237e
    classDef fwNode fill:#fde7e0,stroke:#d93025,color:#b31412
    classDef internetNode fill:#607d8b,stroke:#455a64,color:#ffffff

    class CONSOLE externalNode
    class MWS,DBAPI apiNode
    class GCE1,GCE2,GCE3 gceNode
    class ROUTER,NAT networkNode
    class FW fwNode
    class INTERNET internetNode

    style GCP fill:#e8f5e9,stroke:#2e7d32,stroke-width:3px,color:#1b5e20
    style CP fill:#e8eaf6,stroke:#3949ab,stroke-width:2px,color:#1a237e
    style CMVPC fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1
    style SUBNET fill:#fffde7,stroke:#f9a825,stroke-width:2px,color:#4e342e
    style EGRESS fill:#e0f7fa,stroke:#0097a7,stroke-width:2px,color:#006064
